    {
      "parameters": {
        "jsCode": "// 1. СЧИТАЕМ УЖЕ ЗАПОЛНЕННЫЕ СТРОКИ\nconst allRows = $input.all();\n\nconst filledRows = allRows.filter(item => {\n    const details = item.json['  DETAILS  '] ?? item.json['DETAILS'];\n    const amount = item.json['AMOUNT'];\n    return (details && details.toString().trim() !== '') ||\n           (amount && amount.toString().trim() !== '');\n});\n\nconst count = filledRows.length;\nconst DATA_START_ROW = 3;\nconst targetRow = DATA_START_ROW + count;\n\nlet dataFromBot = {};\ntry {\n    dataFromBot = $('When Executed by Another Workflow').first().json;\n} catch (e) {\n    dataFromBot = {};\n}\n\nconst clean = (value) => String(value ?? '').trim();\nconst existingEntryId = clean(dataFromBot.ENTRY_ID);\nconst seed = `${clean(dataFromBot.DATE)}|${clean(dataFromBot.TYPE)}|${clean(dataFromBot.AMOUNT)}|${clean(dataFromBot.DETAILS)}|${targetRow}`;\nconst hash = Array.from(seed).reduce((acc, ch) => ((acc * 31) + ch.charCodeAt(0)) % 1000000007, 7);\nconst generatedEntryId = `fin_${Date.now()}_${hash}`;\n\nreturn {\n  json: {\n    ...dataFromBot,\n    ENTRY_ID: existingEntryId || generatedEntryId,\n    target_row: targetRow\n  }\n}"
      },

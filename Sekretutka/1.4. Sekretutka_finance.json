      "parameters": {
        "jsCode": "// Determine event type based on finance transaction type\nconst input = $json || {};\nconst typeStr = String(input.TYPE || \"\").toLowerCase().trim();\n\n// Map transaction types to GOLD_GAINED or GOLD_LOST\nconst gainTypes = [\"income\", \"earnings\", \"salary\", \"bonus\", \"reward\", \"gain\", \"received\", \"deposit\"];\nconst eventType = gainTypes.some(gt => typeStr.includes(gt)) ? \"GOLD_GAINED\" : \"GOLD_LOST\";\n\nconst now = new Intl.DateTimeFormat('en-CA', {\n  timeZone: 'Asia/Bangkok',\n  year: 'numeric',\n  month: '2-digit',\n  day: '2-digit',\n  hour: '2-digit',\n  minute: '2-digit',\n  second: '2-digit',\n}).format(new Date());\n\nconst timestamp = now.replace(/^(\\d{4})-(\\d{2})-(\\d{2})\\s/, '$1-$2-$3 ');\n\nreturn {\n  json: {\n    ...input,\n    event_type: eventType,\n    timestamp: timestamp,\n    log_ready: true\n  }\n};"
      },

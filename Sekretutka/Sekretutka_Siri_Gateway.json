    {
      "parameters": {
        "jsCode": "// Формируем ответ для Siri\n// Siri ожидает JSON с полем 'response' или просто текст\nconst agentOutput = $input.first().json.output || 'Готово.';\n\n// Чистим от markdown (Siri читает вслух — форматирование не нужно)\nconst cleaned = agentOutput\n  .replace(/\\*\\*/g, '')\n  .replace(/\\*/g, '')\n  .replace(/#{1,6}\\s/g, '')\n  .replace(/\\[.*?\\]/g, '')  // убираем строки статус-бара\n  .replace(/\\n{3,}/g, '\\n')\n  .trim();\n\n// Берём только первые 2 предложения для голосового ответа\nconst sentences = cleaned.match(/[^.!?]+[.!?]+/g) || [cleaned];\nconst voiceResponse = sentences.slice(0, 2).join(' ').trim();\n\nreturn {\n  json: {\n    response: voiceResponse || 'Готово.',\n    full_response: cleaned\n  }\n};"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        480,
        128
